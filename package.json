{
  "name": "pulsetel",
  "version": "2.0.0",
  "description": "Real-time project telemetry for AI agents and developers. One command to check CI, deploys, endpoints, dependencies, and issues.",
  "main": "dist/index.js",
  "bin": {
    "pulsetel": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "coverage-detailed": "vitest run --coverage --reporter=verbose",
    "dev": "tsc --watch",
    "start": "node dist/index.js mcp",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "agent-tools",
    "ci",
    "health",
    "monitoring",
    "developer-tools",
    "devops",
    "telemetry-cli",
    "ai-agent",
    "telemetry",
    "project-health",
    "anomaly-detection",
    "trend-analysis",
    "dependency-injection",
    "test-coverage"
  ],
  "author": "Sean Cheah",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siongyuen/pulsetel.git"
  },
  "bugs": {
    "url": "https://github.com/siongyuen/pulsetel/issues"
  },
  "homepage": "https://github.com/siongyuen/pulsetel#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "12.0.0",
    "node-fetch": "3.3.2",
    "yaml": "2.4.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/sdk-trace-node": "^1.27.0",
    "@opentelemetry/sdk-metrics": "^1.27.0",
    "@opentelemetry/semantic-conventions": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "20.11.24",
    "@vitest/coverage-v8": "4.1.4",
    "c8": "11.0.0",
    "typescript": "5.4.2",
    "v8-to-istanbul": "9.3.0",
    "vitest": "4.1.4"
  }
}
